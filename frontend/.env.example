# =============================================================================
# Kallpa Nexus — variables de entorno (referencia única)
# Copia las líneas que necesites a:
#   - apps/tenant-web/.env.local
#   - apps/admin-web/.env.local
# En producción, configúralas en el panel del host (Vercel, Azure, etc.).
# La lógica de lectura vive en packages/env/src/knx-env.ts (@kallpanexus/env).
# =============================================================================

# --- API .NET (obligatorio en cada app Next que hace proxy) ---
# URL del backend. Alias preferido en deploy:
KNX_API_URL=https://localhost:7110
# Compatibilidad con nombre anterior (misma prioridad que KNX_API_URL si solo usas uno):
# API_PROXY_TARGET=https://localhost:7110

# --- Modo cliente directo al API (opcional) ---
# Si la defines, el navegador llama al API sin proxy Next (requiere CORS en el backend).
# Déjala vacía para usar mismo origen + /api/* (recomendado detrás de un dominio).
# NEXT_PUBLIC_KNX_API_URL=https://api.tudominio.com

# --- tenant-web (puerto 3000) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEV_TENANT_SUBDOMAIN=sportza
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001/login
# Google Tag Manager (solo rutas públicas: /, /sports, /login, /registrar, /demo…)
# NEXT_PUBLIC_GTM_ID=GTM-NZGLQQW4
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# --- admin-web (puerto 3001) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# NEXT_PUBLIC_TENANT_WEB_URL=http://localhost:3000

# --- Producción (ejemplo) ---
# KNX_API_URL=https://api.kallpanexus.com
# NEXT_PUBLIC_TENANT_WEB_URL=https://app.kallpanexus.com
# NEXT_PUBLIC_APP_URL=https://admin.kallpanexus.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.kallpanexus.com/login
